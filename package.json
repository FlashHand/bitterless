{
  "_name": "BitterLess",
  "version": "1.0.0",
  "versionCode": 2026021501,
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "repository": "git@github.com:FlashHand/bitterless.git",
  "author": "WangBo <ralwayne@163.com>",
  "license": "MIT",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "yarn typecheck:node && yarn typecheck:web",
    "start": "electron-vite preview",
    "dev": "rig --env debug_dev && node scripts/before.js && electron-vite dev",
    "build": "yarn typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && rig postinstall",
    "build:unpack": "yarn build && electron-builder --dir",
    "build:win": "yarn build && electron-builder --win",
    "build:mac": "yarn build && electron-builder --mac",
    "build:linux": "yarn build && electron-builder --linux",
    "preinstall": "rig preinstall"
  },
  "dependencies": {
