{
  "files": [],
  "references": [{ "path": "./tsconfig.node.json" }, { "path": "./tsconfig.web.json" }],
  "compilerOptions": {
    "composite": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/*"
      ],
      "@/*": [
        "src/renderer/home/src/*"
      ],
      "@preload/*": [
        "src/preload/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ]
    }
  },
}
